<mujoco model="scene">

    <include file="../reachy_mini.xml" />
    <compiler meshdir="../assets" texturedir="../assets" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.35 0.28 0.15 1" />
        <global azimuth="160" elevation="-20" offwidth="1280" offheight="720"/>
    </visual>
    <asset>
        <!-- Warm gold-to-dark gradient sky -->
        <texture type="skybox" builtin="gradient" rgb1="0.55 0.40 0.18" rgb2="0.08 0.05 0.02"
                 width="512" height="3072" />
        <!-- Two-tone gold checker floor -->
        <texture type="2d" name="groundplane" builtin="checker" mark="edge"
                 rgb1="0.60 0.45 0.15" rgb2="0.42 0.30 0.10"
                 markrgb="0.70 0.55 0.25" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true"
                  texrepeat="5 5" reflectance="0.2" />
    </asset>

    <worldbody>
        <light pos="-0.5 0 3.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />
    </worldbody>
</mujoco>
